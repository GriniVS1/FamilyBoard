# FamilyBoard OTA updater configuration (installed to /etc/familyboard/updater.env).
# Non-secret. The release public key lives separately at /etc/familyboard/release-pub.pem.
UPDATE_BASE_URL=https://updates.familyboard.ch
UPDATE_CHANNEL=stable
COMPOSE_DIR=/opt/familyboard
RELEASE_PUBKEY=/etc/familyboard/release-pub.pem
STATE_DIR=/var/lib/familyboard
