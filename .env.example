# --- Core ---
# Generate: openssl rand -base64 48
NEXTAUTH_SECRET=replace-with-32+-char-random-string
NEXTAUTH_URL=http://localhost:3000

# 64 hex chars = 32 bytes for AES-256-GCM. Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-hex-chars

# SQLite file. In Docker this points at the bind-mounted volume.
# For local `npm run dev`, use the relative path "file:../data/app.db" — Prisma
# resolves SQLite paths relative to the schema file (prisma/), so ../data lands
# at <project-root>/data/.
DATABASE_URL=file:/app/data/app.db

# --- Google Calendar OAuth ---
# Create a Web Application OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://<host>:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional ---
# Pull Google events every N ms (default 5 min)
SYNC_INTERVAL_MS=300000
