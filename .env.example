# --- Core ---
# Generate: openssl rand -base64 48
NEXTAUTH_SECRET=replace-with-32+-char-random-string
NEXTAUTH_URL=http://localhost:3000

# 64 hex chars = 32 bytes for AES-256-GCM. Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-hex-chars

# SQLite file. In Docker this points at the bind-mounted volume.
# For local `npm run dev`, use the relative path "file:../data/app.db" — Prisma
# resolves SQLite paths relative to the schema file (prisma/), so ../data lands
# at <project-root>/data/.
DATABASE_URL=file:/app/data/app.db

# --- Google Calendar OAuth ---
# Create a Web Application OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://<host>:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft / Outlook Calendar OAuth ---
# 1. Go to https://entra.microsoft.com → Identity → Applications → App registrations → New registration
# 2. Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
# 3. Add a redirect URI (Web platform):
#      http://localhost:3000/api/auth/microsoft/callback   (dev)
#      https://<your-domain>/api/auth/microsoft/callback  (prod)
# 4. Under "API permissions" add delegated permissions:
#      Microsoft Graph → Calendars.ReadWrite, User.Read, offline_access
#    Then "Grant admin consent" (or ask users to consent on first login).
# 5. Under "Certificates & secrets" → "New client secret" → copy the Value (not the ID).
# 6. IMPORTANT: Under "Authentication" ensure "Allow public client flows" is set to NO —
#    this is a confidential client (server-side secret). The toggle defaults to off; verify it.
# 7. Copy the Application (client) ID from the Overview page.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Tenant: use "common" for personal + work accounts, or your specific tenant ID for org-only.
MICROSOFT_TENANT=common

# --- Optional ---
# Pull Google events every N ms (default 5 min)
SYNC_INTERVAL_MS=300000

# VAPID keys for Web Push notifications.
# If left blank, keys are auto-generated on first use and stored in the DB.
# To generate manually: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- License (v3 offline activation) ---
# Ed25519 public key (base64 SPKI DER) used to verify FB1.* license keys offline.
# Generate with: node tool/sign-license.mjs keygen
# When unset, the baked-in dev key is used (safe for development only).
LICENSE_PUBLIC_KEY=

# --- Firebase Cloud Messaging (FCM) — mobile push ---
# Path to your Firebase service-account JSON file.
# Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Keep the file outside the repo (e.g. ./secrets/firebase-service-account.json — already gitignored).
# If left blank, FCM is silently disabled and only web-push is used.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
