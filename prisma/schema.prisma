generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// LicenseStatus values: "UNLICENSED" | "TRIAL" | "ACTIVE" | "EXPIRED"
/// MemberRole values:    "ADMIN" | "MEMBER"
/// EventSource values:   "LOCAL" | "GOOGLE"
/// MealSlot values:      "BREAKFAST" | "LUNCH" | "DINNER" | "SNACK"
/// GroceryCategory:      "produce" | "dairy" | "pantry" | "frozen" | "bakery" | "meat" | "drinks" | "other"
/// Enforced via TypeScript types in src/lib/enums.ts (SQLite has no native enums).

model Installation {
  id                  String     @id @default(cuid())
  familyId            String?    @unique
  family              Family?    @relation(fields: [familyId], references: [id], onDelete: SetNull)
  licenseKey          String?
  licenseStatus       String     @default("UNLICENSED")
  licensePlan         String?
  licenseValidUntil   DateTime?
  lastLicenseCheckAt  DateTime?
  createdAt           DateTime   @default(now())
}

model Family {
  id            String         @id @default(cuid())
  name          String
  weatherLat    Float?
  weatherLon    Float?
  weatherLabel  String?
  createdAt     DateTime       @default(now())
  members       Member[]
  events        Event[]
  chores        Chore[]
  todos         Todo[]
  notes         Note[]
  photos        Photo[]
  installation  Installation?
  recipes       Recipe[]
  mealPlans     MealPlan[]
  groceryItems  GroceryItem[]
}

model Member {
  id                    String          @id @default(cuid())
  familyId              String
  family                Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name                  String
  color                 String
  emoji                 String?
  role                  String          @default("MEMBER")
  googleEmail           String?
  googleRefreshTokenEnc String?
  googleAccessToken     String?
  googleAccessExpiresAt DateTime?
  googleSyncToken       String?
  googleSyncEnabled     Boolean         @default(false)
  createdAt             DateTime        @default(now())
  events                Event[]
  chores                Chore[]
  choreCompletions      ChoreCompletion[]
  todos                 Todo[]
  notesAuthored         Note[]          @relation("NoteAuthor")
  mealPlans             MealPlan[]

  @@index([familyId])
}

model Event {
  id                String        @id @default(cuid())
  familyId          String
  family            Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  memberId          String
  member            Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  location          String?
  startsAt          DateTime
  endsAt            DateTime
  allDay            Boolean       @default(false)
  source            String        @default("LOCAL")
  googleEventId     String?
  googleCalendarId  String?
  color             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([familyId, startsAt])
  @@index([memberId, startsAt])
  @@unique([memberId, googleEventId])
}

model Chore {
  id          String              @id @default(cuid())
  familyId    String
  family      Family              @relation(fields: [familyId], references: [id], onDelete: Cascade)
  memberId    String?
  member      Member?             @relation(fields: [memberId], references: [id], onDelete: SetNull)
  title       String
  icon        String?
  points      Int                 @default(1)
  rrule       String?
  createdAt   DateTime            @default(now())
  completions ChoreCompletion[]

  @@index([familyId])
}

model ChoreCompletion {
  id          String    @id @default(cuid())
  choreId     String
  chore       Chore     @relation(fields: [choreId], references: [id], onDelete: Cascade)
  memberId    String
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  completedAt DateTime  @default(now())

  @@index([memberId, completedAt])
}

model Todo {
  id          String      @id @default(cuid())
  familyId    String
  family      Family      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  memberId    String?
  member      Member?     @relation(fields: [memberId], references: [id], onDelete: SetNull)
  title       String
  done        Boolean     @default(false)
  dueDate     DateTime?
  createdAt   DateTime    @default(now())

  @@index([familyId, done])
}

model Note {
  id              String    @id @default(cuid())
  familyId        String
  family          Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  authorMemberId  String?
  author          Member?   @relation("NoteAuthor", fields: [authorMemberId], references: [id], onDelete: SetNull)
  body            String
  color           String    @default("sun")
  pinned          Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([familyId, pinned])
}

model Photo {
  id          String    @id @default(cuid())
  familyId    String
  family      Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  path        String
  caption     String?
  uploadedAt  DateTime  @default(now())

  @@index([familyId])
}

model Setting {
  key   String  @id
  value String
}

model Recipe {
  id           String       @id @default(cuid())
  familyId     String
  family       Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  servings     Int?
  prepMinutes  Int?
  cookMinutes  Int?
  instructions String?
  sourceUrl    String?
  imageUrl     String?
  tags         String       @default("")
  ingredients  Ingredient[]
  mealPlans    MealPlan[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([familyId])
}

model Ingredient {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name      String
  quantity  String?
  unit      String?
  order     Int     @default(0)

  @@index([recipeId])
}

model MealPlan {
  id         String   @id @default(cuid())
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  date       DateTime
  slot       String
  recipeId   String?
  recipe     Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  customName String?
  notes      String?
  memberId   String?
  member     Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([familyId, date, slot])
  @@index([familyId, date])
}

model GroceryItem {
  id        String   @id @default(cuid())
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name      String
  quantity  String?
  unit      String?
  category  String?
  checked   Boolean  @default(false)
  source    String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId, checked])
}
